# Handsfree — environment template.
#
# Copy this file to `.env` (same directory you run `python -m handsfree` from)
# and fill in the per-machine values. `.env` is gitignored and MUST NOT be
# committed — keep secrets (API keys) only there.
#
#   cp env.dist .env
#
# Every variable below is read by handsfree/config.py.

# Enable debug-level logging (true/false).
DEBUG=true

# ---------------------------------------------------------------------------
# Speech-to-text backend
# ---------------------------------------------------------------------------
# WHISPER_MODE selects how audio is transcribed:
#   api  -> POST the recording to an HTTP Whisper endpoint (WHISPER_URL)
#   cli  -> run a local Whisper command-line tool (WHISPER_CLI_*)
WHISPER_MODE=api

# --- API mode --------------------------------------------------------------
# HTTP endpoint that accepts multipart/form-data (fields: file, model,
# language) and returns JSON with a `text` or `transcription` field.
#
# RECOMMENDED: remote whisper-large-v3 served by vLLM on PGX2 over the LAN.
# This is the OpenAI-compatible /v1/audio/transcriptions endpoint. The model
# id MUST match what PGX2 serves (PGX_WHISPER_MODEL). See the PGX ops repo:
# ai-shared-settings/pgx/vllm-whisper-large/.
WHISPER_URL=http://192.168.5.196:29473/v1/audio/transcriptions
WHISPER_MODEL=openai/whisper-large-v3

# Bearer token for the Whisper endpoint (REQUIRED for the PGX2 service and for
# OpenAI; leave empty for an unauthenticated local server). NEVER commit a real
# key — set it only in your local .env.
API_KEY=

# Alternative API endpoints (uncomment one and adjust WHISPER_MODEL/API_KEY):
#   Local self-hosted whisper.cpp server:
#WHISPER_URL=http://localhost:7777/inference
#   OpenAI hosted Whisper:
#WHISPER_URL=https://api.openai.com/v1/audio/transcriptions
#WHISPER_MODEL=whisper-1

# Spoken language hint passed to Whisper (ISO code, e.g. pl, en).
WHISPER_LANGUAGE=pl

# --- CLI mode (only used when WHISPER_MODE=cli) ----------------------------
# Full command prefix for a local Whisper CLI, e.g. whisper.cpp's whisper-cli.
WHISPER_CLI_COMMAND=/media/mw/Storage/whisper.cpp/build/bin/whisper-cli
# Extra arguments (model path, language, flags). The temp WAV path is appended.
WHISPER_CLI_ARGS=-l pl -nt -m /media/mw/Storage/whisper.cpp/models/ggml-large-v3.bin

# ---------------------------------------------------------------------------
# Recording
# ---------------------------------------------------------------------------
# Hard cap on a single recording's length (seconds); recording auto-stops.
MAX_RECORD_SECONDS=600

# Keep the captured WAV files under recordings/ (true) or discard them (false).
SAVE_RECORDINGS=false

# ---------------------------------------------------------------------------
# Trigger
# ---------------------------------------------------------------------------
# Two trigger styles, selected by DOUBLE_PRESS_WINDOW_MS:
#   > 0  -> "double-tap" mode: two quick presses of DOUBLE_PRESS_KEY within the
#           window (ms) toggle recording; KEYBOARD_SHORTCUT is ignored.
#   = 0  -> classic single shortcut: KEYBOARD_SHORTCUT toggles recording.
DOUBLE_PRESS_WINDOW_MS=800
# Single key for double-tap mode, e.g. ctrl_r, ctrl_l, alt, shift, f1..f12.
DOUBLE_PRESS_KEY=ctrl_r
# Combo used only when DOUBLE_PRESS_WINDOW_MS=0, e.g. alt+f3, ctrl+alt+f5.
KEYBOARD_SHORTCUT=alt+f3

# ---------------------------------------------------------------------------
# Output / typing
# ---------------------------------------------------------------------------
# Notification sounds played on record start/stop.
SOUND_START=handsfree/sounds/start.wav
SOUND_STOP=handsfree/sounds/stop.wav

# Delay (seconds) before the recognized text is typed, to let you release the
# trigger keys / switch focus to the target window.
TYPE_START_DELAY=1.0

# Collapse all whitespace (newlines, tabs, multiple spaces) into single spaces
# before typing (true/false).
REPLACE_ALL_WHITESPACE_WITH_SPACE=true
